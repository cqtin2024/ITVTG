            id: team.id,
            name: team.name,
            group: groupName,
            flag: team.flag
        });
    });
});

// 2. THUẬT TOÁN TỰ ĐỘNG LẬP LỊCH ĐẦY ĐỦ CHO VÒNG BẢNG (72 TRẬN)
// Vòng bảng gồm 12 bảng, mỗi bảng có 4 đội đá vòng tròn 3 lượt -> Tổng 72 trận.
let matchCounter = 1;
const startBaseDate = new Date("2026-06-11"); // Ngày khai mạc World Cup 2026

const timeSlots = ["17:00", "20:00", "23:00", "02:00"]; // Khung giờ đẹp phát sóng tại VN

Object.keys(groupsConfig).forEach((groupName, groupIdx) => {
    const t = groupsConfig[groupName];
    
    // Khung sườn đối đầu vòng bảng chuẩn FIFA xoay vòng
    const roundFixtures = [
        { r: "Matchday 1", h: t[0].id, a: t[1].id },
        { r: "Matchday 1", h: t[2].id, a: t[3].id },
        { r: "Matchday 2", h: t[0].id, a: t[2].id },
        { r: "Matchday 2", h: t[3].id, a: t[1].id },
        { r: "Matchday 3", h: t[3].id, a: t[0].id },
        { r: "Matchday 3", h: t[1].id, a: t[2].id }
    ];

    roundFixtures.forEach((f, fIdx) => {
        // Thuật toán tịnh tiến ngày để các bảng không bị trùng lặp thời gian dày đặc
        let daysOffset = Math.floor((matchCounter - 1) / 4); 
        let matchDate = new Date(startBaseDate);
        matchDate.setDate(startBaseDate.getDate() + daysOffset);
        
        let dateString = matchDate.toISOString().split('T')[0];
        let timeString = timeSlots[(matchCounter - 1) % 4];

        worldCupData.fixtures.push({
            match_no: matchCounter,
            stage: "Group Stage",
            group: groupName,
            round: f.r,
            date: dateString,
            time_vnm: timeString,
            stadium: "Sân vận động FIFA Quốc Tế",
            status: matchCounter === 1 ? "FT" : (matchCounter === 2 ? "LIVE" : "UPCOMING"),
            live_minute: matchCounter === 2 ? "65'" : null,
            home_team: f.h,
            away_team: f.a,
            score: {
                home: matchCounter === 1 ? 2 : (matchCounter === 2 ? 1 : null),
                away: matchCounter === 1 ? 1 : (matchCounter === 2 ? 1 : null)
            }
        });
        matchCounter++;
    });
});

// 3. TỰ ĐỘNG LẬP LỊCH TOÀN BỘ VÒNG ĐỐI ĐẦU TRỰC TIẾP (KNOCKOUT STAGE - 32 TRẬN CÒN LẠI)
// Vòng 32 đội (Trận 73 - 88)
let knockoutStartDate = new Date("2026-06-29");
for (let i = 1; i <= 16; i++) {
    let daysOffset = Math.floor((i - 1) / 4);
    let matchDate = new Date(knockoutStartDate);
    matchDate.setDate(knockoutStartDate.getDate() + daysOffset);

    worldCupData.fixtures.push({
        match_no: matchCounter,
        stage: "Knockout Stage",
        round: "Round of 32",
        date: matchDate.toISOString().split('T')[0],
        time_vnm: timeSlots[(matchCounter - 1) % 4],
        stadium: "Sân vận động KO trung lập",
        status: "UPCOMING",
        home_team: `Nhất/Nhì cụm danh định KO ${i}`,
        away_team: `Nhì/Ba cụm danh định KO ${i}`,
        score: { home: null, away: null }
    });
    matchCounter++;
}

// Vòng 16 đội (Trận 89 - 96)
let r16StartDate = new Date("2026-07-04");
for (let i = 1; i <= 8; i++) {
    let daysOffset = Math.floor((i - 1) / 2);
    let matchDate = new Date(r16StartDate);
    matchDate.setDate(r16StartDate.getDate() + daysOffset);

    worldCupData.fixtures.push({
        match_no: matchCounter,
        stage: "Knockout Stage",
        round: "Round of 16",
        date: matchDate.toISOString().split('T')[0],
        time_vnm: i % 2 === 0 ? "02:00" : "06:00",
        stadium: "Sân vận động Vòng 16 đội",
        status: "UPCOMING",
        home_team: `Thắng trận ${72 + (i * 2 - 1)}`,
        away_team: `Thắng trận ${72 + (i * 2)}`,
        score: { home: null, away: null }
    });
    matchCounter++;
}

// Vòng Tứ kết (Trận 97 - 100)
let qfStartDate = new Date("2026-07-09");
